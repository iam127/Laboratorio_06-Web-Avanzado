<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Nuevo Post</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
</head>
<body class="grey lighten-4">
  <nav>
    <div class="nav-wrapper teal">
      <a href="/" class="brand-logo center">Social Media</a>
    </div>
  </nav>
  <div class="container" style="margin-top: 30px;">
    <h4>Crear Nuevo Post</h4>
    <form action="/posts/create" method="POST">
      <div class="input-field">
        <input type="text" name="title" id="title" required>
        <label for="title">Título (5-30 caracteres)</label>
      </div>
      <div class="input-field">
        <textarea name="content" id="content" class="materialize-textarea" required></textarea>
        <label for="content">Contenido (mínimo 10 caracteres)</label>
      </div>
      <div class="input-field">
        <input type="text" name="hashtags" id="hashtags">
        <label for="hashtags">Hashtags (separados por coma)</label>
      </div>
      <div class="input-field">
        <input type="text" name="imageUrl" id="imageUrl">
        <label for="imageUrl">URL de imagen</label>
      </div>
      <div class="input-field">
        <input type="text" name="userId" id="userId" required>
        <label for="userId">ID del Usuario</label>
      </div>
      <button type="submit" class="btn teal waves-effect waves-light">
        <i class="material-icons left">save</i>Guardar
      </button>
      <a href="/posts" class="btn grey waves-effect waves-light">Cancelar</a>
    </form>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>