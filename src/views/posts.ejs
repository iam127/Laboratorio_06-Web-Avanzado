<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Social Media - Posts</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="grey lighten-4">
  <nav>
    <div class="nav-wrapper teal">
      <a href="/" class="brand-logo center">Social Media</a>
    </div>
  </nav>
  <div class="container" style="margin-top: 30px;">
    <div class="row">
      <div class="col s12">
        <a href="/posts/create" class="btn green waves-effect waves-light">
          <i class="material-icons left">add</i>Nuevo Post
        </a>
      </div>
    </div>
    <div class="row">
      <% posts.forEach(post => { %>
      <div class="col s12 m6 l4">
        <div class="card">
          <% if (post.imageUrl) { %>
          <div class="card-image">
            <img src="<%= post.imageUrl %>" alt="Imagen del post">
          </div>
          <% } %>
          <div class="card-content">
            <span class="card-title"><%= post.title %></span>
            <p><%= post.content %></p>
            <% if (post.hashtags && post.hashtags.length > 0) { %>
            <p style="margin-top:10px;">
              <% post.hashtags.forEach(tag => { %>
              <span class="chip">#<%= tag %></span>
              <% }) %>
            </p>
            <% } %>
          </div>
          <div class="card-action">
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: nowrap;">
              <span style="flex: 1;"><strong>Autor:</strong> <%= post.user ? post.user.name + ' ' + post.user.lastName : 'Sin autor' %></span>
              <div style="display: flex; align-items: center; gap: 5px;">
                <a href="/posts/edit/<%= post._id %>" class="btn-flat" style="padding: 0 5px;">
                  <i class="material-icons teal-text">edit</i>
                </a>
                <form action="/posts/delete/<%= post._id %>" method="POST" style="display:inline; margin:0;">
                  <button type="submit" class="btn-flat" style="padding: 0 5px;">
                    <i class="material-icons red-text">delete</i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>