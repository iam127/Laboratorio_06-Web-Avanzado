<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Social Media - Posts</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav>
    <div class="nav-wrapper" style="padding: 0 24px;">
      <a href="/" class="brand-logo center">
        <i class="material-icons" style="vertical-align: middle; margin-right: 8px;">people</i>
        Social Media
      </a>
    </div>
  </nav>

  <div class="container" style="margin-top: 40px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
      <h5 class="page-title">Publicaciones</h5>
      <a href="/posts/create" class="btn btn-red waves-effect waves-light">
        <i class="material-icons left">add</i>Nuevo Post
      </a>
    </div>

    <div class="row">
      <% posts.forEach(post => { %>
      <div class="col s12 m6 l4">
        <div class="card">
          <% if (post.imageUrl) { %>
          <div class="card-image">
            <img src="<%= post.imageUrl %>" alt="Imagen del post">
          </div>
          <% } %>
          <div class="card-content">
            <span class="card-title"><%= post.title %></span>
            <p style="margin-top: 8px;"><%= post.content %></p>
            <% if (post.hashtags && post.hashtags.length > 0) { %>
            <p style="margin-top: 12px;">
              <% post.hashtags.forEach(tag => { %>
              <span class="chip">#<%= tag %></span>
              <% }) %>
            </p>
            <% } %>
          </div>
          <div class="card-action">
            <div style="display: flex; justify-content: space-between; align-items: center;">
              <span class="autor">
                <i class="material-icons" style="font-size:16px; vertical-align: middle; color:#b71c1c;">person</i>
                <%= post.user ? post.user.name + ' ' + post.user.lastName : 'Sin autor' %>
              </span>
              <div>
                <a href="/posts/edit/<%= post._id %>" class="btn-flat">
                  <i class="material-icons" style="color: #b71c1c;">edit</i>
                </a>
                <form action="/posts/delete/<%= post._id %>" method="POST" style="display:inline; margin:0;">
                  <button type="submit" class="btn-flat">
                    <i class="material-icons" style="color: #757575;">delete</i>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
</body>
</html>